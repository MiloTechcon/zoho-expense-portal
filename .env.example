# === Required: License (provided by Techcon Solution at onboarding) ===
LICENSE_KEY=

# === Required: Image version (e.g. v1.4 — do NOT use :latest) ===
APP_VERSION_TAG=v1.4

# === Required: Zoho Books Self Client ===
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# === Required: app secret (generate a 48-byte random base64) ===
JWT_SECRET=

# === Required: database (default works inside compose) ===
DATABASE_URL=postgresql://postgres:postgres@db:5432/expenses

# === Required: Ollama (host install, accessed via host.docker.internal) ===
OLLAMA_HOST=host.docker.internal:11434
OLLAMA_MODEL=qwen3-vl:8b

# === Required: at least one paid-through default ===
DEFAULT_PAID_THROUGH_ACCOUNT=HSBC HK

# === Optional: per-user paid-through mapping ===
# Syntax: ';' separates users, ',' separates that user's accounts (first = default).
# PAID_THROUGH_ACCOUNT_MAP=milo=Director C/A-Mr Yung (P),Director C/A-Mr Yung;kobe=Director C/A-Mr Lau (P),Director C/A-Mr Lau

# === Optional: auto-scan ingest (Kodak / scanner folder) ===
# SCAN_HOST_DIR=
# SCAN_DEFAULT_USERNAME=
# SCAN_STABILITY_SECONDS=3
# SCAN_MAX_PER_TICK=10
# Map scanner subfolders to (user, paid-through account):
#   'Folder=user,Account' entries separated by ';'
# SCAN_FOLDER_ACCOUNT_MAP=Milo=milo,Director C/A-Mr Yung;Milo_P=milo,Director C/A-Mr Yung (P)

# === Optional: blank-scan guard (reject files smaller than N bytes pre-OCR) ===
# MIN_RECEIPT_SIZE_BYTES=5120        # default 5 KB; 0 disables

# === Optional: review flags (catch OCR mis-reads before they reach Zoho) ===
# EXPENSE_MIN_DATE=2024-08-15        # flag receipts dated before this; blank = off
# EXPENSE_FUTURE_GRACE_DAYS=1        # days past today allowed before flagging a future date
# AMOUNT_OUTLIER_ENABLED=true        # learn each vendor's normal amount range, flag outliers
# AMOUNT_OUTLIER_MIN_SAMPLES=5       # past expenses needed for a vendor before judging
# AMOUNT_OUTLIER_IQR_FACTOR=2.5      # higher = more tolerant
# AMOUNT_OUTLIER_MIN_TOLERANCE_PCT=40

# === Optional: email notifications (Resend) — alert a director on review/failed items ===
# Leave RESEND_API_KEY blank to keep notifications off.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=alerts@your-domain.com          # must be a Resend-verified sender
# APP_BASE_URL=https://your-portal-url        # used for the link in the email
# REVIEW_NOTIFY_EMAIL=fallback@your-domain.com  # optional; for scanner items with no owner
# Then set each director's address:
#   docker compose exec zoho-expense-web python /app/run_manage.py set-email <username> <email>

# === Optional: branding ===
# BRAND_NAME=
# BRAND_LOGO_URL=/static/custom/your-logo.png

# === Optional: Cloudflare tunnel (run with --profile cloudflare) ===
# CLOUDFLARE_TUNNEL_TOKEN=
